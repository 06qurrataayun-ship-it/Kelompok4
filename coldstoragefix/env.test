# ─── Environment Variables – Cold Storage IoT ─────────────────────────────
# Salin file ini menjadi .env lalu sesuaikan nilainya
# Di terminal: cp .env.example .env

# ── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
# Jika broker butuh autentikasi:
# MQTT_USERNAME=username_anda
# MQTT_PASSWORD=password_anda

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Lokal tanpa autentikasi:
MONGO_URI=mongodb://localhost:27017/

# MongoDB Atlas (cloud) – ganti dengan connection string Anda:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB lokal dengan autentikasi:
# MONGO_URI=mongodb://admin:password@localhost:27017/

# ── Nama Database ─────────────────────────────────────────────────────────────
# (tidak perlu diubah kecuali ingin berbeda)
# DB_NAME=kelompok4
